# Surcharges d'environnement pour les tests (prioritaires sur .env).
# Base dédiée : les tests migrent/rollbackent app_test sans toucher aux données de dev.
DB_DATABASE=app_test
# Store mémoire : pas de cookies signés à gérer pour manipuler la session en test.
SESSION_DRIVER=memory
# Serveur HTTP de test sur un port distinct pour ne pas entrer en conflit
# avec le serveur de dev (3333).
HOST=127.0.0.1
PORT=3334

# ⚠️ Immich neutralisé, et c'est une garantie, pas une commodité (CC-55).
#
# `.env.test` surcharge `.env` : sans ces trois lignes, les tests hériteraient de
# l'instance RÉELLE du poste — clé d'API comprise. Un `container.swap` oublié suffirait
# alors à faire partir de vraies requêtes vers une vraie bibliothèque de photos pendant
# `npm test`, sans que rien ne le signale.
#
# Vidées, `immichConfig.enabled` vaut `false` et `ImmichClient` refuse de partir avant
# même de construire une URL. « Aucun test ne touche une vraie instance » devient une
# propriété du dispositif, pas une promesse. Les tests qui ont besoin d'une
# configuration en passent une explicitement (`ensureSource(config)`).
IMMICH_BASE_URL=
IMMICH_API_KEY=
IMMICH_ALBUM_ID=
