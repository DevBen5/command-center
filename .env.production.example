# =============================================================================
# Command Center — modèle d'environnement de PRODUCTION.
#
# Copier puis remplir (AUCUNE valeur réelle ne doit vivre dans ce dépôt) :
#   cp .env.production.example .env.production
#
# Générer APP_KEY (voir plus bas) puis lancer :
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d
#
# Le drapeau --env-file est nécessaire : il alimente l'interpolation ${...} du
# bloc postgres du compose. `env_file:` (côté app) n'injecte, lui, que dans le
# conteneur ; les deux pointent le même fichier.
# =============================================================================

# --- Processus -----------------------------------------------------------------
NODE_ENV=production

# Fuseau du process : c'est dans celui-là que s'écrivent et se relisent les
# timestamps de la base. Le changer après coup ferait dériver l'interprétation des
# lignes déjà enregistrées.
TZ=UTC

# Fuseau des collectes de veille « à heure fixe » (distinct de TZ, pas un doublon).
# Optionnel (défaut Europe/Paris). Un nom invalide fait échouer le démarrage.
APP_TIMEZONE=Europe/Paris

# Port et interface d'écoute DANS le conteneur. `::` = dual-stack (IPv4 + IPv6).
# Le Dockerfile fixe déjà ces valeurs par défaut ; les garder ici les rend visibles.
PORT=8080
HOST=::

LOG_LEVEL=info

# Sessions signées côté cookie : aucun stockage serveur à monter.
SESSION_DRIVER=cookie

# --- Clé applicative -----------------------------------------------------------
# OBLIGATOIRE. Signe cookies et sessions. La générer une fois, la garder stable
# (la changer invalide toutes les sessions). Sans image déjà construite :
#   docker compose --env-file .env.production -f docker-compose.prod.yml run --rm app node ace generate:key
# Copier la valeur produite ci-dessous.
APP_KEY=

# --- Base de données -----------------------------------------------------------
# ⚠️ DB_HOST = `postgres`, le NOM DU SERVICE du compose (pas 127.0.0.1, qui
# désignerait le conteneur applicatif lui-même). DB_PORT = 5432, le port INTERNE
# (aucun port n'est publié en prod).
DB_HOST=postgres
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=app

# Emplacement des données Postgres sur l'hôte. Défaut ./pgdata (à côté du compose).
# ⚠️ Sur le NAS, un chemin ABSOLU (ex. /volume1/docker/command-center/pgdata). Ce
# dossier appartient à Postgres et est lié à PG 16 ; ce n'est PAS une sauvegarde.
PGDATA_PATH=./pgdata

# --- Premier compte (seed unique, CC-75) ---------------------------------------
# Les migrations sont jouées automatiquement au démarrage du conteneur ; le SEED
# ne l'est pas. Pour créer le compte propriétaire, une seule fois : renseigner la
# variable ci-dessous (12 caractères minimum) puis lancer une fois :
#   docker compose --env-file .env.production -f docker-compose.prod.yml run --rm app node ace db:seed
# ⚠️ Retirer ensuite la ligne : rien d'autre ne la lit, la garder laisse un secret
#    en clair. La reposer et relancer db:seed est aussi la façon de CHANGER le mot
#    de passe du propriétaire (updateOrCreate écrase).
# ADMIN_PASSWORD=

# --- Serveur LLM local (ingestion Leitner) — optionnel -------------------------
# Depuis le NAS, c'est une adresse du réseau local (LM Studio sur le PC, p. ex.).
# ⚠️ PC éteint = juge en repli silencieux (voulu) : la révision ne tombe jamais.
# Toutes optionnelles ; défauts dans config/llm.ts.
# LLM_BASE_URL=http://192.168.x.x:1234/v1
# LLM_MODEL=local-model
# LLM_API_KEY=
# LLM_TIMEOUT_MS=120000

# --- Instance Immich (source média de la veille) — optionnel -------------------
# ⚠️ IMMICH_ALBUM_ID est l'UUID d'UN album, jamais la bibliothèque entière.
# Le slash final de IMMICH_BASE_URL est retiré par config/immich.ts.
# Toutes optionnelles ; sans elles, la collecte Immich reste inactive.
# IMMICH_BASE_URL=https://immich.exemple.fr
# IMMICH_API_KEY=
# IMMICH_ALBUM_ID=
# IMMICH_TIMEOUT_MS=15000
