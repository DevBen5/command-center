TZ=UTC
# Fuseau des collectes de veille à heure fixe (« tous les jours à 7h »).
#
# ⚠️ Distinct de TZ, et pas un doublon. TZ est le fuseau du process : c'est dans
# celui-là que s'écrivent et se relisent les `timestamp` de la base — le changer
# ferait dériver l'interprétation des lignes déjà enregistrées. APP_TIMEZONE ne
# situe que la fenêtre horaire d'une source en mode `daily`. Sans lui, « 7h » saisi
# à Paris se déclencherait à 9h l'été, sans que rien ne le signale.
#
# Optionnel (défaut Europe/Paris, dans config/veille.ts). Un nom de fuseau invalide
# fait échouer le démarrage : c'est délibéré — un fuseau illisible rendrait toute
# comparaison de dates fausse, et les sources horaires cesseraient d'être collectées
# en silence.
APP_TIMEZONE=Europe/Paris
PORT=3333
# `::` = dual-stack (IPv4 + IPv6). `localhost` peut se lier en IPv6 seul sur
# Windows et rendre le serveur injoignable depuis un navigateur en IPv4.
HOST=::
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=app

# Serveur LLM local, compatible OpenAI (POST {LLM_BASE_URL}/chat/completions) :
# LM Studio, llama.cpp --server, vLLM… Sert à l'ingestion d'un cours en cartes
# Leitner (/revision/ingest).
#
# ⚠️ La configuration vit ICI, jamais en base : c'est la seule façon de garantir
# que la valeur utilisée par le serveur ne soit pas modifiable par une requête HTTP.
# /revision/llm détecte le serveur, teste le modèle et FABRIQUE ce bloc — il ne
# l'écrit pas : colle-le, et redémarre (l'environnement est lu au démarrage).
# Toutes ces variables sont optionnelles ; leurs défauts sont dans config/llm.ts.
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=local-model
# LLM_API_KEY=
LLM_TIMEOUT_MS=120000

# Instance Immich — la source des vidéos et images de veille (CC-55).
#
# ⚠️ Même frontière de confiance que le LLM : ces valeurs vivent ICI, jamais en base
# et jamais dans un formulaire. Une URL de serveur persistée depuis une requête HTTP
# serait une SSRF permanente, écrite une fois et rejouée à chaque collecte.
#
# ⚠️ IMMICH_ALBUM_ID est l'UUID d'UN album — jamais la bibliothèque entière, qui
# contient des photos personnelles (et que le lot 3 enverrait à un LLM). L'utilisateur
# dépose dans cet album ce qui relève de la veille, depuis Immich : le filtre est chez
# lui, dans l'outil qu'il utilise déjà. L'UUID se lit dans l'URL de l'album.
#
# ⚠️ Le slash final de IMMICH_BASE_URL est retiré par config/immich.ts, et il FAUT
# qu'il le soit : `<base>//api/...` ne rend pas une 404 mais 200 + le HTML de
# l'interface Immich. Un client qui ne teste que le statut lirait « album vide ».
#
# Les trois sont optionnelles : sans elles, la collecte Immich reste inactive et la
# source correspondante est désactivée avec un message explicite.
# IMMICH_BASE_URL=https://immich.exemple.fr
# IMMICH_API_KEY=
# IMMICH_ALBUM_ID=
# IMMICH_TIMEOUT_MS=15000